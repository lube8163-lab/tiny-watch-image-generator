{
  "version": "watch75_sdxl_tiny_v7_focus_freeprompt",
  "description": "Focused V7 teacher supplement for the v6 watch model. It keeps the existing vocabulary but targets food, clean symbols, tools, vehicles, and action/view pairs with lower-texture single-subject SDXL prompts.",
  "default_negative_prompt": "text, logo, watermark, caption, signature, letters, low quality, blurry, noisy, distorted, deformed, cropped subject, multiple subjects, duplicate subject, repeated subject, many copies, group, collection, set, array, row of objects, icon sheet, collage, tiled layout, pattern, seamless pattern, repeating pattern, wallpaper, decorative background, decorative frame, ornamental border, stripes, checkerboard, busy background, cluttered background, detailed scenery, crowd, people in background, grain, speckles, mottled texture, paper texture, canvas texture, dirty background, noisy background, background pattern, tiny details, photorealistic clutter",
  "defaults": {
    "views_v2": [
      "front view",
      "side view",
      "closeup",
      "top view"
    ],
    "styles_v2": [
      "icon",
      "cartoon",
      "toy",
      "sketch"
    ],
    "modifiers_v2": [
      "simple",
      "small",
      "round",
      "bright"
    ]
  },
  "variants": [
    {
      "variant": "clean00",
      "conditioning_prompt": "{key}",
      "prompt": "exactly one {subject}, isolated single subject, centered, full subject visible, flat vector style, smooth solid fills, minimal shading, clean readable silhouette, plain matte light gray background, empty background, no texture, no grain, no paper texture, not a collection{guard_clause}, no text, no logo, no watermark"
    },
    {
      "variant": "clean01",
      "conditioning_prompt": "simple {key}",
      "prompt": "exactly one {subject}, very simple rounded object icon, centered, large clear silhouette, flat vector style, smooth solid fills, minimal shading, clean readable silhouette, plain matte light gray background, empty background, no texture, no grain, no paper texture, not a collection{guard_clause}, no text, no logo, no watermark"
    },
    {
      "variant": "icon00",
      "conditioning_prompt": "icon {key}",
      "prompt": "exactly one {subject}, centered object icon, full subject visible, simple icon style, bold outline, smooth solid color areas, high contrast readable shape, plain light gray background, empty background, no texture, no pattern, no repeated objects, not a collection{guard_clause}, no text, no logo, no watermark"
    },
    {
      "variant": "cartoon00",
      "conditioning_prompt": "cartoon {key}",
      "prompt": "exactly one {subject}, simple cartoon icon, centered, full subject visible, flat vector style, smooth solid fills, minimal shading, clean readable silhouette, plain matte light gray background, empty background, no texture, no grain, no paper texture, no repeated objects, not a collection{guard_clause}, no text, no logo, no watermark"
    },
    {
      "variant": "toy00",
      "conditioning_prompt": "toy {key}",
