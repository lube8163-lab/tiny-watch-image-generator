{
  "version": "watch75_sdxl_tiny_v8_slot_freeprompt",
  "description": "Eval-aligned V8 teacher supplement for color/action/view/style slot binding. This is intentionally narrower than v7 and should be mixed with existing base/focus datasets.",
  "default_negative_prompt": "text, logo, watermark, caption, signature, letters, low quality, blurry, noisy, distorted, deformed, cropped subject, multiple subjects, duplicate subject, repeated subject, many copies, group, collection, set, array, row of objects, icon sheet, collage, tiled layout, pattern, seamless pattern, repeating pattern, wallpaper, decorative background, decorative frame, ornamental border, stripes, checkerboard, busy background, cluttered background, detailed scenery, crowd, people in background, grain, speckles, mottled texture, paper texture, canvas texture, dirty background, noisy background, background pattern, complex scenery, repeated objects, tiny details, photorealistic clutter",
