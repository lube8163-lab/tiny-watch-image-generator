{
  "version": "watch75_sdxl_tiny_v8_slot_freeprompt",
  "description": "Eval-aligned V8 teacher supplement for color/action/view/style slot binding. This is intentionally narrower than v7 and should be mixed with existing base/focus datasets.",
  "default_negative_prompt": "text, logo, watermark, blurry, noisy, deformed, cropped subject, multiple subjects, group, duplicate subject, collection, collage, patterned background, busy background, cluttered background, scenery, crowd, grain, speckles",
  "defaults": {
    "colors_v2": [
      "red",
      "blue",
      "white",
      "black",
      "pink",
      "yellow",
      "green"
    ],
    "views_v2": [
      "front view",
      "side view",
      "top view",
      "closeup"
    ],
    "styles_v2": [
      "icon",
      "cartoon",
      "toy",
      "anime",
      "watercolor",
      "sketch",
      "photo"
    ],
    "modifiers_v2": [
      "simple",
      "small",
      "clear",
      "bright"
    ]
  },
  "variants": [
    {
      "variant": "slot_base00",
      "conditioning_prompt": "{key}",
      "prompt": "exactly one {subject}, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_base01",
      "conditioning_prompt": "simple {key}",
      "prompt": "exactly one {subject}, simple icon, large clear shape, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_color_{color_token}",
      "slot_source": {
        "color": "colors_v2"
      },
      "max_expansions": 7,
      "conditioning_prompt": "{color} {key}",
      "prompt": "exactly one {color} {subject}, clearly {color}, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_action_{action_token}",
      "slot_source": {
        "action": "actions_v2"
      },
      "max_expansions": 5,
      "conditioning_prompt": "{key} {action}",
      "prompt": "exactly one {subject} {action}, simple readable pose, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_view_{view_token}",
      "slot_source": {
        "view": "views_v2"
      },
      "max_expansions": 4,
      "conditioning_prompt": "{key} {view}",
      "prompt": "exactly one {subject}, {view}, clear viewpoint, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_style_simple_{style_token}",
      "slot_values": {
        "style": [
          "icon",
          "cartoon",
          "toy"
        ]
      },
      "conditioning_prompt": "{style} {key}",
      "prompt": "exactly one {subject}, {style} style, bold simple outline, smooth solid color areas, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects, no text{guard_clause}"
    },
    {
      "variant": "slot_style_art_{style_token}",
      "slot_values": {
        "style": [
          "anime",
          "watercolor",
          "sketch"
        ]
      },
      "conditioning_prompt": "{style} {key}",
      "prompt": "exactly one {subject}, {style} style, simple clean illustration, minimal detail, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects, no text{guard_clause}"
    },
    {
      "variant": "slot_style_photo",
      "slot_values": {
        "style": [
          "photo"
        ]
      },
      "conditioning_prompt": "{style} {key}",
      "prompt": "studio product photo of exactly one {subject}, simple soft lighting, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects, no text{guard_clause}"
    },
    {
      "variant": "slot_color_action_{color_token}_{action_token}",
      "slot_source": {
        "color": "colors_v2",
        "action": "actions_v2"
      },
      "slot_strategy": "zip_cycle",
      "max_expansions": 7,
      "conditioning_prompt": "{color} {key} {action}",
      "prompt": "exactly one {color} {subject} {action}, clearly {color}, simple readable pose, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_action_view_{action_token}_{view_token}",
      "slot_source": {
        "action": "actions_v2",
        "view": "views_v2"
      },
      "slot_strategy": "zip_cycle",
      "max_expansions": 8,
      "conditioning_prompt": "{key} {action} {view}",
      "prompt": "exactly one {subject} {action}, {view}, clear pose and viewpoint, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_style_color_{style_token}_{color_token}",
      "slot_source": {
        "style": "styles_v2",
        "color": "colors_v2"
      },
      "slot_strategy": "zip_cycle",
      "max_expansions": 7,
      "conditioning_prompt": "{style} {color} {key}",
      "prompt": "exactly one {color} {subject}, {style} style, clearly {color}, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    },
    {
      "variant": "slot_full_{style_token}_{color_token}_{action_token}_{view_token}",
      "slot_source": {
        "style": "styles_v2",
        "color": "colors_v2",
        "action": "actions_v2",
        "view": "views_v2"
      },
      "slot_strategy": "zip_cycle",
      "max_expansions": 14,
      "conditioning_prompt": "{style} {color} {key} {action} {view}",
      "prompt": "exactly one {color} {subject} {action}, {view}, {style} style, clear color, pose, and viewpoint, centered, whole subject visible, readable silhouette, plain light gray background, empty background, single subject only, no repeated objects{guard_clause}, no scenery, no text"
    }
  ],
