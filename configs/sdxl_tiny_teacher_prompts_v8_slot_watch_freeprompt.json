        "action": "actions_v2"
      },
      "max_expansions": 5,
      "conditioning_prompt": "{key} {action}",
      "prompt": "exactly one {subject} {action}, exaggerated simple readable pose, clear limb or body direction when applicable, isolated single subject, centered, full subject visible, clear readable silhouette, plain matte light gray background, empty background, low texture, smooth simple shading, no repeated objects, not a collection{guard_clause}, no scenery, no background pattern, no text, no logo, no watermark"
    },
