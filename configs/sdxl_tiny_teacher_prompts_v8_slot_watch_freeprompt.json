      "bright"
    ]
  },
  "variants": [
    {
      "variant": "slot_base00",
      "conditioning_prompt": "{key}",
      "prompt": "exactly one {subject}, isolated single subject, centered, full subject visible, clear readable silhouette, plain matte light gray background, empty background, low texture, smooth simple shading, no repeated objects, not a collection{guard_clause}, no scenery, no background pattern, no text, no logo, no watermark"
    },
    {
      "variant": "slot_base01",
      "conditioning_prompt": "simple {key}",
      "prompt": "exactly one {subject}, simple object icon, large clear shape, isolated single subject, centered, full subject visible, clear readable silhouette, plain matte light gray background, empty background, low texture, smooth simple shading, no repeated objects, not a collection{guard_clause}, no scenery, no background pattern, no text, no logo, no watermark"
    },
    {
      "variant": "slot_color_{color_token}",
      "slot_source": {
        "color": "colors_v2"
      },
      "max_expansions": 7,
      "conditioning_prompt": "{color} {key}",
      "prompt": "exactly one {color} {subject}, the whole subject is clearly {color}, isolated single subject, centered, full subject visible, clear readable silhouette, plain matte light gray background, empty background, low texture, smooth simple shading, no repeated objects, not a collection{guard_clause}, no scenery, no background pattern, no text, no logo, no watermark"
    },
    {
