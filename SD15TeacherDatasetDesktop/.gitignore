.DS_Store

# Local build products and dependency caches
.build/
.cache/
.venv/
.pycache/
__pycache__/
.swiftpm/
DerivedData/
build/

# Xcode user state
*.xcuserstate
xcuserdata/
*.moved-aside
*.xcuserdatad/

# Generated model artifacts are too large for normal GitHub storage.
artifacts/*
!artifacts/.gitkeep
recipes/*
!recipes/.gitkeep

# Generated archives and model packages
*.zip
*.tar
*.tar.gz
*.mlmodelc/
*.mlpackage/
*.pth

# Secrets
.env
*.env
